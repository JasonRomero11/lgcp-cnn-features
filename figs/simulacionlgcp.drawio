        <mxCell id="odLNtXMsl5hoeShkW0gD-200" parent="1" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=12;shadow=1;sketch=1;curveFitting=1;jiggle=2;autosizeText=0;verticalAlign=middle;fontSize=11;" value="$$\textbf{TARGETS} \\ \boldsymbol{\theta}_i = (\mu_i,\ \sigma^2_i,\ s_i) \\ \\ \textbf{INPUTS} \\ L_c(r) = \hat{L}(r) - r \\ N_i \\ \mathbf{f}_i \in \mathbb{R}^{8} \\ \\ \textit{Quadrat-based } (c_k) \\ f_1 = \mathrm{Var}(c_k) \\ f_2 = \mathrm{Var}(c_k)/\bar{c} \\ f_3 = \max_k c_k / (\min_k c_k + 1) \\ \\ \textit{KDE-based } (\hat{\lambda}) \\ f_4 = \mathrm{Var}(\hat{\lambda}) \\ f_5 = \mathrm{skew}(\hat{\lambda}) \\ f_6 = \mathrm{kurt}(\hat{\lambda}) \\ f_7 = H(\hat{\lambda}) \\ f_8 = \mathrm{SD}(\hat{\lambda})/\bar{\hat{\lambda}}$$" vertex="1">
